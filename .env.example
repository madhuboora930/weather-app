# All of these have working defaults baked into src/services/*.js, so the
# app runs with zero configuration. Override them here only if you want to
# point at a different provider (e.g. a self-hosted proxy, or swapping in
# OpenWeatherMap later).

VITE_WEATHER_BASE_URL=https://api.open-meteo.com/v1
VITE_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1
VITE_REVERSE_GEOCODING_BASE_URL=https://api.bigdatacloud.net/data
